        </div>
        <nav class="mobile-nav">
            <a href="index.html"><i class="fas fa-home"></i> Home</a>
            <a href="about.html"><i class="fas fa-church"></i> About</a>
            <a href="ministry.html"><i class="fas fa-hands-helping"></i> Ministry</a>
            <a href="outreach.html"><i class="fas fa-heart"></i> Outreach</a>
            <a href="courses.html"><i class="fas fa-graduation-cap"></i> Courses</a>
            <a href="gallery.html"><i class="fas fa-images"></i> Gallery</a>
            <a href="blog.html"><i class="fas fa-newspaper"></i> Blog</a>
            <a href="resources.html"><i class="fas fa-download"></i> Resources</a>
            <a href="connect.html"><i class="fas fa-envelope"></i> Connect</a>
            <a href="contact.html"><i class="fas fa-map-marker-alt"></i> Contact</a>
        </nav>
        <div class="mobile-footer" style="padding:1.5rem;text-align:center;font-size:0.75rem;border-top:1px solid #f3f4f6;"><p>© 2025 Faith Bible International Church</p></div>
