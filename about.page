    <!-- Page Hero -->
    <section class="page-hero">
        <div class="container">
            <h1>About Us</h1>
            <p>Discover the heart and vision of Faith Bible International Church</p>
        </div>
    </section>

    <!-- Our Story -->
    <section class="story-section">
        <div class="container">
            <div class="story-grid">
                <div class="story-content">
                    <span class="section-tag">Our Story</span>
                    <h2>Rooted in Faith, <br>Reaching Ethiopia and the World</h2>
                    <p>Faith Bible International Church was founded in Gerji, Addis Ababa, with a simple vision: to create a community where people could encounter God through His Word and experience authentic relationships. What began as a small home Bible study has grown into a vibrant, multi-cultural church family.</p>
                    <p style="margin-top: 1rem;">Today, we continue to hold fast to our core values: the authority of Scripture, the power of prayer, the importance of community, and the urgency of the Great Commission.</p>
                </div>
                <div class="story-image">
                    <div style="background: linear-gradient(135deg, #F5F3FF, #EDE9FE); border-radius: 2rem; height: 350px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
                        <i class="fas fa-church" style="font-size: 5rem; color: #8B5CF6; margin-bottom: 1rem;"></i>
                        <span style="color: #4C1D95; font-weight: 500;">Faith Bible Church<br>Gerji Mebrat Hail, Addis Ababa</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="mission-section">
        <div class="container">
            <div class="mission-grid">
                <div class="mission-card">
                    <i class="fas fa-bullseye"></i>
                    <h3 style="margin-bottom: 0.75rem;">Our Mission</h3>
                    <p>To glorify God by making disciples of Jesus Christ who love God, love people, and reach the world with the Gospel.</p>
                </div>
                <div class="mission-card">
                    <i class="fas fa-eye"></i>
                    <h3 style="margin-bottom: 0.75rem;">Our Vision</h3>
                    <p>A thriving, multi-ethnic church family where every believer is equipped, engaged, and empowered for ministry.</p>
                </div>
                <div class="mission-card">
                    <i class="fas fa-handshake"></i>
                    <h3 style="margin-bottom: 0.75rem;">Our Values</h3>
                    <p>Bible-centered teaching · Authentic worship · Compassionate outreach · Generational discipleship</p>
                </div>
            </div>
        </div>
    </section>

    <!-- What We Believe -->
    <section style="padding: 5rem 0; background: white; text-align: center;">
        <div class="container">
            <span class="section-tag">Our Beliefs</span>
            <h2 class="section-title">What We Believe</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 2rem;">
                <div style="padding: 1.5rem; background: #FAF9FE; border-radius: 1rem;">
                    <h4 style="color: #6D28D9; margin-bottom: 0.5rem;">The Bible</h4>
                    <p>We believe the Bible is the inspired, infallible Word of God.</p>
                </div>
                <div style="padding: 1.5rem; background: #FAF9FE; border-radius: 1rem;">
                    <h4 style="color: #6D28D9; margin-bottom: 0.5rem;">The Trinity</h4>
                    <p>We believe in one God existing in three persons: Father, Son, and Holy Spirit.</p>
                </div>
                <div style="padding: 1.5rem; background: #FAF9FE; border-radius: 1rem;">
                    <h4 style="color: #6D28D9; margin-bottom: 0.5rem;">Salvation</h4>
                    <p>We believe salvation is by grace through faith in Jesus Christ alone.</p>
                </div>
                <div style="padding: 1.5rem; background: #FAF9FE; border-radius: 1rem;">
                    <h4 style="color: #6D28D9; margin-bottom: 0.5rem;">The Church</h4>
                    <p>We believe the Church is the body of Christ called to make disciples.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Leadership Team -->
    <section style="padding: 5rem 0; background: #FAF9FE; text-align: center;">
        <div class="container">
            <span class="section-tag">Leadership</span>
            <h2 class="section-title">Meet Our Pastoral Team</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 2rem;">
                <div style="background: white; padding: 2rem; border-radius: 1.5rem;">
                    <i class="fas fa-user-circle" style="font-size: 5rem; color: #7C3AED; margin-bottom: 1rem;"></i>
                    <h4>Dr. Michael Thompson</h4>
                    <p style="color: #6b7280;">Senior Pastor</p>
                </div>
                <div style="background: white; padding: 2rem; border-radius: 1.5rem;">
                    <i class="fas fa-user-circle" style="font-size: 5rem; color: #7C3AED; margin-bottom: 1rem;"></i>
                    <h4>Pastor Sarah Williams</h4>
                    <p style="color: #6b7280;">Associate Pastor</p>
                </div>
                <div style="background: white; padding: 2rem; border-radius: 1.5rem;">
                    <i class="fas fa-user-circle" style="font-size: 5rem; color: #7C3AED; margin-bottom: 1rem;"></i>
                    <h4>Pastor David Chen</h4>
                    <p style="color: #6b7280;">Worship & Creative Arts</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section style="padding: 4rem 0;">
        <div class="container">
            <div style="background: linear-gradient(135deg, #4C1D95, #7C3AED); padding: 3rem; border-radius: 2rem; text-align: center; color: white;">
                <i class="fas fa-heart" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                <h3 style="margin-bottom: 0.5rem;">Become Part of Our Family</h3>
                <p>We'd love to welcome you to Faith Bible International Church</p>
                <a href="connect.html" class="btn-primary" style="display: inline-block; margin-top: 1.5rem; background: white; color: #6D28D9; box-shadow: none;">Plan Your Visit →</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-about">
                    <div class="footer-logo"><i class="fas fa-cross"></i><span>Faith Bible International Church</span></div>
                    <p>Proclaiming Christ, Building Believers, Reaching the World.</p>
                </div>
                <div class="footer-links">
                    <h4 style="color: white; margin-bottom: 1rem;">Quick Links</h4>
                    <ul style="list-style: none;">
                        <li style="margin-bottom: 0.5rem;"><a href="about.html" style="color: #cbd5e1; text-decoration: none;">About Us</a></li>
                        <li style="margin-bottom: 0.5rem;"><a href="courses.html" style="color: #cbd5e1; text-decoration: none;">Free Courses</a></li>
                        <li style="margin-bottom: 0.5rem;"><a href="resources.html" style="color: #cbd5e1; text-decoration: none;">Resources</a></li>
                    </ul>
                </div>
                <div class="footer-contact">
                    <h4 style="color: white; margin-bottom: 1rem;">Contact Us</h4>
                    <p><i class="fas fa-map-marker-alt"></i> Gerji Mebrat Hail, Addis Ababa, Ethiopia</p>
                    <p><i class="fas fa-phone"></i> +251-XXX-XXX-XXX</p>
                    <p><i class="fas fa-envelope"></i> info@faithbibleethiopia.org</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 Faith Bible International Church. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        // Mobile menu functionality
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileOverlay = document.getElementById('mobile-overlay');
        const closeMenuBtn = document.getElementById('close-menu-btn');

        function openMenu() {
            if (mobileMenu && mobileOverlay) {
                mobileMenu.classList.add('open');
                mobileOverlay.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
        }

        function closeMenu() {
            if (mobileMenu && mobileOverlay) {
                mobileMenu.classList.remove('open');
                mobileOverlay.classList.remove('open');
                document.body.style.overflow = '';
            }
        }

        if (menuToggle) menuToggle.addEventListener('click', openMenu);
        if (closeMenuBtn) closeMenuBtn.addEventListener('click', closeMenu);
        if (mobileOverlay) mobileOverlay.addEventListener('click', closeMenu);
    </script>
</body>
</html>
